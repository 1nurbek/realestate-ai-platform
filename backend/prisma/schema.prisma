generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  LAND
  COMMERCIAL
}

enum PropertyStatus {
  ACTIVE
  PENDING
  SOLD
}

model User {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  password         String
  role             UserRole        @default(USER)
  avatar           String?
  phone            String?
  properties       Property[]
  favorites        Favorite[]
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  searchHistories  SearchHistory[]
  reviews          Review[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([role])
  @@index([createdAt])
}

model Property {
  id             String         @id @default(cuid())
  title          String
  description    String
  price          Decimal        @db.Decimal(12, 2)
  location       String
  address        String
  latitude       Decimal?       @db.Decimal(10, 7)
  longitude      Decimal?       @db.Decimal(10, 7)
  size           Decimal        @db.Decimal(10, 2)
  rooms          Int
  bathrooms      Int
  type           PropertyType
  status         PropertyStatus @default(ACTIVE)
  images         String[]
  features       String[]
  userId         String
  categoryId     String
  views          Int            @default(0)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  favorites      Favorite[]
  messages       Message[]
  reviews        Review[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([status, type])
  @@index([location])
  @@index([price])
  @@index([createdAt])
}

model Category {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  icon       String?
  properties Property[]

  @@index([slug])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@index([createdAt])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  propertyId String
  read       Boolean  @default(false)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([propertyId])
  @@index([read])
  @@index([createdAt])
}

model SearchHistory {
  id        String   @id @default(cuid())
  query     String
  filters   Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([userId])
  @@index([createdAt])
}